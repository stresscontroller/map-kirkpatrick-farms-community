{
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "module"
  },
  "plugins": ["@typescript-eslint"],
  "extends": [
    "eslint:recommended",
    "plugin:@typescript-eslint/recommended",
    "plugin:prettier/recommended"
  ],
  "rules": {
    "prettier/prettier": "error",
    "no-console": "warn",
    "indent": ["error", 2],
    "quotes": ["error", "single"],
    "@typescript-eslint/no-explicit-any": "error",
    "semi": ["error", "always"]
  }
}
