{
  "name": "oneco-backend-auth-service",
  "version": "1.0.0",
  "description": "Auth service of the oneco-bank mircoservice backend",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "nodemon ./dist/index.js",
    "dev": "nodemon ./src/index.ts",
    "build": "npx tsc",
    "lint": "eslint --ignore-path .eslintignore --ext ./src/**/*.ts",
    "lint:fix": "eslint './src/**/*.ts' --fix",
    "format": "prettier --ignore-path .gitignore --write \"**/*.+(js|ts|json)\"",
    "format:check": "prettier --check src/**/*.ts",
    "prepare": "husky install .husky",
    "pre-commit": "npx pretty-quick --staged && lint-staged"
  },
  "author": "Moyo Alabi (Lead full-stack engineer @oneco)",
  "license": "ISC",
  "dependencies": {
    "@types/chalk": "^2.2.0",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/uuid": "^9.0.8",
    "bcrypt": "^5.1.1",
    "chalk": "^4.1.2",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "joi": "^17.12.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.3.1",
    "nodemailer": "^6.9.13",
    "nodemon": "^3.1.0",
    "prom-client": "^15.1.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/nodemailer": "^6.4.14",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "globals": "^15.9.0",
    "husky": "^9.1.5",
    "lint-staged": "^15.2.9",
    "prettier": "^3.3.3",
    "typescript": "^5.4.4",
    "typescript-eslint": "^8.2.0"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write",
      "git add"
    ]
  }
}
